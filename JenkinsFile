pipeline {
  agent {
    docker {
      image 'python:3.12-slim'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Setup and Test') {
      steps {
        sh '''
          pip install --upgrade pip
          pip install -r requirements.txt
          python manage.py test
        '''
      }
    }

    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://3.80.122.105:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'sonar-scanner -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL} -Dsonar.projectKey=my-django-project -Dsonar.sources=.'
        }
      }
    }

    stage('Build and Push Docker Image') {
      environment {
        DOCKER_IMAGE = "stelabiju/ultimate-cicd:${BUILD_NUMBER}"
      }
      steps {
        script {
          sh 'docker build -t ${DOCKER_IMAGE} .'
          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            def dockerImage = docker.image("${DOCKER_IMAGE}")
            dockerImage.push()
          }
        }
      }
    }

    stage('Update Deployment File') {
      environment {
        GIT_REPO_NAME = "Django_CI-CD"
        GIT_USER_NAME = "stelabiju"
      }
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            git config --global user.email "stelabiju@gmail.com"
            git config --global user.name "stelabiju"
            
            git fetch origin main
            git checkout main
            git reset --hard origin/main

            # Update the manifest
            sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" django-manifests/deployment.yml

            git add django-manifests/deployment.yml
            git commit -m "Update deployment image to ${BUILD_NUMBER}" || echo "No changes"
            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git main
          '''
        }
      }
    }
  }
}
